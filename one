SELECT
  wl.workspace_id,
  wl.workspace_name,
  COUNT(DISTINCT c.storage_root) AS storage_root_count
FROM system.compute.workspaces_latest wl
LEFT JOIN system.information_schema.catalogs c
  ON 1 = 1
WHERE c.storage_root IS NOT NULL
GROUP BY
  wl.workspace_id,
  wl.workspace_name
ORDER BY storage_root_count DESC;
